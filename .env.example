# Plantilla de credenciales. Copia este archivo a `.env` y rellena los valores.
# `.env` está en .gitignore: NUNCA se sube al repo.
#
#   cp .env.example .env
#
# En GitHub Actions NO se usa este archivo: define POESESSID y CONTACT_EMAIL
# como Secrets del repo (Settings -> Secrets and variables -> Actions).

# Cookie de sesion de pathofexile.com (DevTools -> Application -> Cookies).
# Si se deja vacia, el recolector funciona en modo MOCK (datos sinteticos).
POESESSID=

# Email de contacto: GGG exige un User-Agent identificativo.
CONTACT_EMAIL=tu-email@example.com
